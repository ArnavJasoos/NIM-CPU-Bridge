# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
#
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
NGC_API_KEY=nvapi-YOUR_KEY_HERE

# ── NIM image to run (pick one) ───────────────────────────────────────────────
NIM_IMAGE=nvcr.io/nim/meta/llama-3.1-8b-instruct:latest
NIM_MODEL_NAME=meta/llama-3.1-8b-instruct

# Other tested images:
# NIM_IMAGE=nvcr.io/nim/mistralai/mistral-7b-instruct-v0.3:latest
# NIM_MODEL_NAME=mistralai/mistral-7b-instruct-v0.3
#
# NIM_IMAGE=nvcr.io/nim/microsoft/phi-3-mini-4k-instruct:latest
# NIM_MODEL_NAME=microsoft/phi-3-mini-4k-instruct

# ── CPU Backend ───────────────────────────────────────────────────────────────
# auto | llama_cpp | onnxruntime | ctransformers
NCB_BACKEND=auto

# ── Quantisation (GGUF level) ─────────────────────────────────────────────────
# Q2_K | Q3_K_M | Q4_K_M (default) | Q5_K_M | Q6_K | Q8_0 | F16
NCB_QUANT=Q4_K_M

# ── Context window (tokens) ───────────────────────────────────────────────────
NCB_CONTEXT_LEN=4096

# ── CPU threads (0 = auto-detect physical core count) ────────────────────────
NCB_THREADS=0

# ── Fake GPU properties reported to NIM ──────────────────────────────────────
NCB_FAKE_GPU_NAME=Tesla T4
NCB_FAKE_VRAM_MB=16384

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARN
NCB_LOG_LEVEL=INFO

# ── Service port exposed on the host ─────────────────────────────────────────
NCB_HOST_PORT=8000

# ── Weight conversion ─────────────────────────────────────────────────────────
# Set to false if you pre-converted with scripts/pull_and_convert.sh
NCB_CONVERT_ON_START=true

# ── Model cache location on the host ─────────────────────────────────────────
# Default: ~/.cache/nim   (mounted as a Docker volume)
NIM_CACHE_HOST_PATH=~/.cache/nim
